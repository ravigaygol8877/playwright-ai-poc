{
  "name": "playwright-ai-poc",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "ai:run": "tsx scripts/run-pipeline.ts",
    "ai:run:qa": "ENVIRONMENT=qa tsx scripts/run-pipeline.ts",
    "ai:run:uat": "ENVIRONMENT=uat tsx scripts/run-pipeline.ts",
    "project:reset": "tsx scripts/project-reset.ts",
    "demo": "tsx scripts/demo.ts",
    "kb:generate": "tsx scripts/generate-kb.ts",
    "generate": "tsx pipeline/index.ts",
    "generate:pom": "tsx scripts/generate-pom.ts",
    "generate:from-excel": "tsx scripts/generate-from-excel.ts",
    "requirements:template": "tsx scripts/create-requirements-template.ts",
    "generate:all": "tsx scripts/generate-all.ts",
    "generate:all:qa": "ENVIRONMENT=qa tsx scripts/generate-all.ts",
    "generate:all:uat": "ENVIRONMENT=uat tsx scripts/generate-all.ts",
    "test": "playwright test",
    "test:qa": "ENVIRONMENT=qa dotenv -e config/environments/qa.env -- playwright test --project=chromium",
    "test:uat": "ENVIRONMENT=uat dotenv -e config/environments/uat.env -- playwright test --project=chromium",
    "test:prod": "ENVIRONMENT=production dotenv -e config/environments/production.env -- playwright test --project=chromium",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "report": "playwright show-report reports/latest/playwright",
    "report:latest": "playwright show-report reports/latest/playwright",
    "allure:generate": "allure generate reports/latest/allure/results --output reports/latest/allure/report --clean",
    "allure:open": "allure open reports/latest/allure/report",
    "allure:serve": "allure serve reports/latest/allure/results",
    "allure:full": "npm test && npm run allure:generate && npm run allure:open",
    "demo:flaky": "tsx scripts/demo-flaky.ts",
    "demo:rootcause": "tsx scripts/demo-rootcause.ts",
    "demo:healing": "tsx scripts/demo-healing.ts",
    "demo:coverage": "tsx scripts/demo-coverage.ts",
    "demo:regression": "tsx scripts/demo-regression.ts",
    "test:github-models": "LLM_PROVIDER=github-models MODEL=gpt-4.1 tsx scripts/test-github-models.ts",
    "test:provider-switching": "tsx scripts/test-provider-switching.ts",
    "cache:clear": "node -e \"const fs=require('fs'); if(fs.existsSync('.llm-cache')){fs.rmSync('.llm-cache',{recursive:true,force:true});console.log('LLM cache cleared.');}else{console.log('No cache to clear.');}\" ",
    "test:smoke": "npx playwright test --grep @smoke",
    "test:regression": "npx playwright test --grep @regression",
    "test:mobile": "npx playwright test --grep @mobile",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ravigaygol8877/playwright-ai-poc.git"
  },
  "keywords": [],
  "author": "Ravi Gaygol",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/ravigaygol8877/playwright-ai-poc/issues"
  },
  "homepage": "https://github.com/ravigaygol8877/playwright-ai-poc#readme",
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.1",
    "eslint": "^9.0.0",
    "eslint-plugin-playwright": "^2.10.4",
    "prettier": "^3.8.5",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "jsonrepair": "^3.14.1",
    "openai": "^6.44.0"
  }
}
