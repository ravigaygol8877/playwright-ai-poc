# ──────────────────────────────────────────────────────────────────────────────
# AI Test Intelligence Platform — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# LLM provider to use: gemini | github-models | openrouter | lm-studio | fallback
LLM_PROVIDER=fallback

# Comma-separated fallback chain (used when LLM_PROVIDER=fallback)
FALLBACK_CHAIN=gemini,github-models,openrouter,lm-studio

# ── LM Studio (local, no API key needed) ──────────────────────────────────────
# Start the LM Studio server before running the pipeline.
# Download: https://lmstudio.ai
LM_STUDIO_URL=http://127.0.0.1:1234
MODEL=google/gemma-4-e4b

# ── Cloud providers ───────────────────────────────────────────────────────────
# Obtain keys from each provider's console.

# Google Gemini — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# GitHub Models (requires GitHub personal access token with models:read scope)
# https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# OpenRouter — https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
